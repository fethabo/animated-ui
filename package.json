{
  "name": "@fethabo/animated-ui",
  "version": "0.6.4",
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^24.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "description": "Lightweight animated UI components for React. Zero runtime dependencies, tree-shakeable, fully customizable via CSS custom properties (--aui-*).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./animated-background": {
      "types": "./dist/animated-background.d.ts",
      "import": "./dist/animated-background.js",
      "require": "./dist/animated-background.cjs"
    },
    "./pixel-background": {
      "types": "./dist/pixel-background.d.ts",
      "import": "./dist/pixel-background.js",
      "require": "./dist/pixel-background.cjs"
    },
    "./tilt-card": {
      "types": "./dist/tilt-card.d.ts",
      "import": "./dist/tilt-card.js",
      "require": "./dist/tilt-card.cjs"
    },
    "./spotlight-card": {
      "types": "./dist/spotlight-card.d.ts",
      "import": "./dist/spotlight-card.js",
      "require": "./dist/spotlight-card.cjs"
    },
    "./glow-border": {
      "types": "./dist/glow-border.d.ts",
      "import": "./dist/glow-border.js",
      "require": "./dist/glow-border.cjs"
    },
    "./magnetic-element": {
      "types": "./dist/magnetic-element.d.ts",
      "import": "./dist/magnetic-element.js",
      "require": "./dist/magnetic-element.cjs"
    },
    "./shiny-text": {
      "types": "./dist/shiny-text.d.ts",
      "import": "./dist/shiny-text.js",
      "require": "./dist/shiny-text.cjs"
    },
    "./scramble-text": {
      "types": "./dist/scramble-text.d.ts",
      "import": "./dist/scramble-text.js",
      "require": "./dist/scramble-text.cjs"
    },
    "./scroll-reveal": {
      "types": "./dist/scroll-reveal.d.ts",
      "import": "./dist/scroll-reveal.js",
      "require": "./dist/scroll-reveal.cjs"
    },
    "./typewriter-text": {
      "types": "./dist/typewriter-text.d.ts",
      "import": "./dist/typewriter-text.js",
      "require": "./dist/typewriter-text.cjs"
    },
    "./split-reveal": {
      "types": "./dist/split-reveal.d.ts",
      "import": "./dist/split-reveal.js",
      "require": "./dist/split-reveal.cjs"
    },
    "./stacked-cards": {
      "types": "./dist/stacked-cards.d.ts",
      "import": "./dist/stacked-cards.js",
      "require": "./dist/stacked-cards.cjs"
    },
    "./mouse-parallax": {
      "types": "./dist/mouse-parallax.d.ts",
      "import": "./dist/mouse-parallax.js",
      "require": "./dist/mouse-parallax.cjs"
    },
    "./parallax-layers": {
      "types": "./dist/parallax-layers.d.ts",
      "import": "./dist/parallax-layers.js",
      "require": "./dist/parallax-layers.cjs"
    },
    "./scroll-progress": {
      "types": "./dist/scroll-progress.d.ts",
      "import": "./dist/scroll-progress.js",
      "require": "./dist/scroll-progress.cjs"
    },
    "./particle-field": {
      "types": "./dist/particle-field.d.ts",
      "import": "./dist/particle-field.js",
      "require": "./dist/particle-field.cjs"
    },
    "./image-dissolve": {
      "types": "./dist/image-dissolve.d.ts",
      "import": "./dist/image-dissolve.js",
      "require": "./dist/image-dissolve.cjs"
    },
    "./sticky-scenes": {
      "types": "./dist/sticky-scenes.d.ts",
      "import": "./dist/sticky-scenes.js",
      "require": "./dist/sticky-scenes.cjs"
    },
    "./circuit-background": {
      "types": "./dist/circuit-background.d.ts",
      "import": "./dist/circuit-background.js",
      "require": "./dist/circuit-background.cjs"
    },
    "./tesla-coil": {
      "types": "./dist/tesla-coil.d.ts",
      "import": "./dist/tesla-coil.js",
      "require": "./dist/tesla-coil.cjs"
    },
    "./attention-cue": {
      "types": "./dist/attention-cue.d.ts",
      "import": "./dist/attention-cue.js",
      "require": "./dist/attention-cue.cjs"
    },
    "./guiding-branches": {
      "types": "./dist/guiding-branches.d.ts",
      "import": "./dist/guiding-branches.js",
      "require": "./dist/guiding-branches.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "release": "node ./scripts/release.mjs",
    "release:dry-run": "node ./scripts/release.mjs --dry-run",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "react",
    "animation",
    "components",
    "background",
    "tilt",
    "canvas",
    "css",
    "tree-shakeable"
  ]
}
