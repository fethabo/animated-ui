# SPA routing para Apache (Hostinger). Toda ruta que no sea un archivo o
# directorio real se sirve con index.html; el router de la app resuelve la vista.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # No reescribir archivos ni directorios existentes (assets, imágenes, etc.).
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Todo lo demás → index.html (deep links y recarga de /es/components/<slug>).
  RewriteRule ^ index.html [L]
</IfModule>

# Cache largo para assets con hash en el nombre (inmutables).
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|svg|png|jpg|jpeg|gif|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # index.html nunca se cachea: es el punto de entrada que apunta a los assets.
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
